# CoderWiki Backend Environment Configuration
# Copy this file to .env and modify the values as needed

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
WTF_CSRF_SECRET_KEY=your-csrf-secret-key-here

# Database Configuration
DATABASE_URL=mysql+pymysql://coderwiki_user:coderwiki_password@localhost:3306/coderwiki
DEV_DATABASE_URL=mysql+pymysql://coderwiki_user:coderwiki_password@localhost:3306/coderwiki_dev

# LLM Configuration
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
LLM_PROVIDER=openai

# MCP Service Configuration
MCP_ENABLED=true
MCP_SERVER_URL=http://localhost
MCP_SERVER_PORT=3000

# Git Configuration
GIT_REPOS_PATH=./repos

# Logging Configuration
LOG_LEVEL=INFO

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
