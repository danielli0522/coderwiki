# 数据库配置
DATABASE_URL=mysql+pymysql://username:password@localhost/coderwiki

# Flask 配置
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
DEBUG=True

# Claude Code 配置
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_WORKSPACE_ID=your-claude-workspace-id-here

# BMAD 代理配置
BMAD_AGENTS_PATH=bmad-docs-generator
BMAD_WORKFLOW_TIMEOUT=300

# 文档生成配置
REPOSITORY_BASE_PATH=backend/repos
MAX_FILE_SIZE=10485760
MAX_FILES_PER_REPO=1000

# 其他配置
LOG_LEVEL=INFO
